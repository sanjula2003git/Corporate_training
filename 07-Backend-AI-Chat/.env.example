# Phase 2 AI chat — copy this file to ".env" and fill in a key to go live.
# Without any key, the chat still works using a built-in mock reply.
#
#   copy .env.example .env       (Windows)
#
# RECOMMENDED — Google Gemini (has a FREE tier).
# Get a key in ~1 minute at:  https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OPTIONAL — Anthropic Claude instead (paid). Used only if GEMINI_API_KEY is blank.
# ANTHROPIC_API_KEY=
